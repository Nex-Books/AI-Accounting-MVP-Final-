# NexBooks — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — SERVER ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── OpenAI ────────────────────────────────────────────────────────────────────
# Used for AI chat (gpt-4o-mini) and document OCR (gpt-4o Vision)
OPENAI_API_KEY=sk-...

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Cron Jobs ─────────────────────────────────────────────────────────────────
# Used to authenticate the monthly usage reset cron at /api/cron/reset-usage
# Set this to any long random string. In Vercel, add a cron job with this header:
#   Authorization: Bearer <CRON_SECRET>
CRON_SECRET=your-random-cron-secret

# ─── Razorpay (optional — required for paid plan subscriptions) ─────────────────
# Found in: Razorpay Dashboard → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your-razorpay-secret
# Webhook secret from: Razorpay Dashboard → Settings → Webhooks
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
